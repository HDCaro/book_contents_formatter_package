# ================================================================================
# Python - Testing and Coverage
# ================================================================================
htmlcov/                # HTML coverage reports
.tox/                   # tox test automation
.nox/                   # nox test automation
.coverage               # coverage.py data file
.coverage.*             # coverage.py variations
.cache                  # pytest cache
nosetests.xml           # nose test output
coverage.xml            # coverage XML output
*.cover                 # coverage reports
*.py,cover              # coverage variations
.hypothesis/            # Hypothesis test data
.pytest_cache/          # pytest cache directory
cover/                  # coverage directory

# ================================================================================
# Python - Virtual Environments
# ================================================================================
# Virtual environment directories vary by tool; ignore all common patterns
# Rationale: Each dev machine creates fresh venv; not needed in version control
.env                    # environment variables file
.venv                   # pipenv virtual environment
env/                    # generic venv directory
venv/                   # standard python venv
ENV/                    # alternate capitalization
env.bak/                # backup venv
venv.bak/               # backup venv

# ================================================================================
# IDE / Text Editors
# ================================================================================
# IDE configuration is user-specific; don't force on collaborators
.vscode/                # Visual Studio Code settings
.idea/                  # JetBrains IDE (PyCharm, IntelliJ)
*.swp                   # vim swap file
*.swo                   # vim swap file (older)
*~                      # emacs/vim backup
.DS_Store               # macOS system file
Thumbs.db               # Windows thumbnail cache

# ================================================================================
# Jupyter Notebook
# ================================================================================
# Jupyter generates checkpoint files that shouldn't be versioned
.ipynb_checkpoints      # Jupyter automatic checkpoint saves

# ================================================================================
# IPython
# ================================================================================
# IPython configuration is user-specific
profile_default/        # IPython default profile
ipython_config.py       # IPython configuration file

# ================================================================================
# Version Management Tools
# ================================================================================
# Ignore version-specific configuration files
.python-version         # pyenv version specification
Pipfile.lock            # pipenv lock file (lock files are too large)
poetry.lock             # poetry lock file
celerybeat-schedule     # celery beat schedule
celerybeat.pid          # celery beat process ID

# ================================================================================
# Generated Python Files
# ================================================================================
# SageMath creates these during computation
*.sage.py               # SageMath parsed output

# ================================================================================
# Environment Variable Files
# ================================================================================
# IMPORTANT: Never version actual .env files - they may contain secrets!
.env                    # main environment file
.env.local              # local development overrides
.env.development.local  # development-specific
.env.test.local         # testing-specific
.env.production.local   # production-specific

# ================================================================================
# Static Analysis Tools
# ================================================================================
# Ignore caches and output from various linters and type checkers
.mypy_cache/            # mypy type checking cache
.dmypy.json             # dmypy daemon config
dmypy.json              # dmypy output
.pyre/                  # Pyre type checker cache
.pytype/                # pytype static analyzer cache
cython_debug/           # Cython debug symbols

# ================================================================================
# IDE-Specific Tools
# ================================================================================
# Ignore project-specific IDE tool configurations
.spyderproject          # Spyder IDE project file
.spyproject             # Spyder IDE settings
.ropeproject            # Rope (Python refactoring library) project
/site                   # mkdocs documentation site

# ================================================================================
# Archive Files
# ================================================================================
# Compressed archives shouldn't be in version control (extract as needed)
*.7z                    # 7-Zip archive
*.zip                   # ZIP archive
*.rar                   # RAR archive
*.tar.gz                # tar + gzip

# ================================================================================
# Temporary Files
# ================================================================================
# Various temporary file patterns
temp/                   # temporary directory
tmp/                    # temporary directory
*.tmp                   # temporary file
*.temp                  # temporary file

# ================================================================================
# Log Files
# ================================================================================
# Logs are generated during runtime and shouldn't be versioned
*.log                   # generic log file
logs/                   # logs directory

# ================================================================================
# Backup Files
# ================================================================================
# Backup files created by editors shouldn't be committed
*.bak                   # generic backup
*.backup                # generic backup
*~                      # emacs backup
# ================================================================================
# Book Contents Formatter - Python Package .gitignore
# ================================================================================
# This file controls what files are tracked in version control.
# Strategy: Keep source code and documentation in git; exclude generated outputs,
# dependencies, and large working files (locally available for development).
#
# Key Principle: INPUT FILES TRACKED, OUTPUT FILES IGNORED
# - books/<slug>/inputs/: source documents tracked for reproducibility
# - books/<slug>/outputs/: generated stage outputs ignored
# - books/<slug>/work/: generated working files ignored selectively
# ================================================================================

# ================================================================================
# Book Data Management
# ================================================================================
# Keep all book inputs and release snapshots tracked by default.
!books/*/inputs/
!books/*/inputs/**
!books/*/release/
!books/*/release/**

# Ignore Word HTML sidecar folders accidentally created next to source DOCX files.
books/*/inputs/book_body/*_files/

# Ignore generated stage outputs.
books/*/outputs/

# Ignore front matter temp files.
books/*/work/front_matter/temp/

# Ignore generated index reports.
books/*/work/index/reports/

# Ignore regenerated index intermediates.
books/*/work/index/intermediate/index_raw.json
books/*/work/index/intermediate/index_raw_fixed.json
books/*/work/index/intermediate/index_raw_excluded.json
books/*/work/index/intermediate/index_discrepancies.json
books/*/work/index/intermediate/index_transaction_suggestions.json
books/*/work/index/intermediate/index_curated_old_pages.json
books/*/work/index/intermediate/index_curated_final.json

# Keep editorial working files tracked unless the workflow proves they are disposable.
!books/*/work/index/intermediate/index_curated_old.json
!books/*/work/index/intermediate/index_transaction_edit.json
!books/*/work/index/intermediate/index_curated_extracted.json
!books/*/work/index/intermediate/index_curated_extracted_fixed.json
!books/*/work/index/reports/index_curated_extracted_edit.csv

# ================================================================================
# Document Files - Generated Word Documents
# ================================================================================
# Global rule: ignore all .docx (Word documents)
# Rationale: .docx files are binary, large (>100MB), and generated/intermediate
*.docx

# Do not track book DOCX files in git. Keep them local and reference them via config.

# Ignore Word lock files everywhere
~$*.docx

# ================================================================================
# Python - Compiled Files and Virtual Environments
# ================================================================================
# Ignore Python bytecode and compiled files
__pycache__/
*.py[cod]      # .pyc, .pyo, .pyd
*$py.class
*.so            # C extensions

# Ignore package build artifacts
.Python         # Virtual env marker
build/          # build distribution
develop-eggs/   # setuptools development eggs
dist/           # distribution
downloads/      # pip downloads
eggs/           # setuptools eggs
.eggs/          # local eggs
lib/            # build output
lib64/          # 64-bit build output
parts/          # buildout parts
sdist/          # source distribution
var/            # misc build output
wheels/         # wheel distributions
share/python-wheels/  # shared wheels
*.egg-info/     # egg metadata
.installed.cfg  # setuptools config
*.egg           # egg archive
MANIFEST        # setuptools manifest

# ================================================================================
# Python - PyInstaller Artifacts
# ================================================================================
# These are created when using PyInstaller for executable creation
*.manifest      # Windows manifest
*.spec          # PyInstaller spec file

# ================================================================================
# Python - Installer and Dependency Logs
# ================================================================================
# Keep repo clean from dependency resolution logs
pip-log.txt                   # pip operation log
pip-delete-this-directory.txt # pip cleanup marker

