{
  "task": "full_book",
  "description": "Assemble full book: join front matter + body + index with section breaks and preserved formatting",
  "inputs": {
    "front_matter_file": "outputs/01_front_matter/front_matter.docx",
    "book_body_file": "inputs/book_body/main_body.docx",
    "index_file": "inputs/index_source/approved_index_source.docx",
    "front_matter_metadata": "outputs/01_front_matter/front_matter.config.json",
    "index_metadata": "outputs/02_index/index.config.json"
  },
  "outputs": {
    "output_dir": "outputs/03_full_book",
    "filename": "full_book.docx",
    "metadata_filename": "full_book.config.json"
  },
  "options": {
    "preserve_section_formatting": true,
    "section_breaks": "nextpage"
  }
}
